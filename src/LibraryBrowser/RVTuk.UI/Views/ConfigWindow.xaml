<Window x:Class="RVTuk.UI.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RVTuk — Config"
        Width="560" Height="560" MinWidth="460" MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RVTuk.UI;component/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Background><StaticResource ResourceKey="Brush.Bg"/></Window.Background>
    <Window.Foreground><StaticResource ResourceKey="Brush.Text"/></Window.Foreground>

    <TabControl Margin="8" Background="{StaticResource Brush.Bg}">
        <!-- More tabs (other tools' settings) get added here later. -->
        <TabItem Header="Family Library">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,20,22,22" MaxWidth="480">

                    <TextBlock Text="LIBRARY ROOT FOLDER"
                               Foreground="{StaticResource Brush.TextMuted}" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" IsReadOnly="True" Margin="0,0,6,0"
                                 Text="{Binding LibraryFolderPath, Mode=OneWay}"
                                 Foreground="{StaticResource Brush.TextMuted}"/>
                        <Button Grid.Column="1" Content="Browse…" Width="72"
                                Command="{Binding BrowseLibraryCommand}"/>
                    </Grid>
                    <TextBlock Foreground="{StaticResource Brush.TextMuted}" FontSize="10"
                               Margin="0,5,0,0" TextWrapping="Wrap">
                        The .Setup folder with the database will be created here automatically.
                    </TextBlock>

                    <Separator Margin="0,26,0,22"/>

                    <TextBlock Text="DEEP SCAN" Foreground="{StaticResource Brush.TextMuted}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"
                               Foreground="{StaticResource Brush.Text}">
                        Deep scan extracts full metadata — category, parameters, and thumbnail —
                        from family files using the Revit engine.
                        <LineBreak/><LineBreak/>
                        <Run FontWeight="SemiBold">Scan New &amp; Changed</Run> only re-reads families
                        that are new or whose file changed — fast.
                        <LineBreak/>
                        <Run FontWeight="SemiBold">Re-scan All Families</Run> re-reads every family
                        (use when parameters or thumbnails are missing) and removes families whose
                        files are gone. Your instructions, pictures, tags, and favourites are kept.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ScanNewCommand}" Margin="0,0,10,0"
                                Padding="14,7" Background="{StaticResource Brush.AccentDark}"
                                BorderBrush="{StaticResource Brush.Accent}"
                                Content="Scan New &amp; Changed"/>
                        <Button Command="{Binding RescanAllCommand}"
                                Padding="14,7"
                                Content="Re-scan All Families"/>
                    </StackPanel>

                    <Separator Margin="0,26,0,22"/>

                    <TextBlock Text="IGNORED SUBFOLDERS" Foreground="{StaticResource Brush.TextMuted}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox AcceptsReturn="True" Height="80"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding IgnoredSubfoldersText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                    <TextBlock Foreground="{StaticResource Brush.TextMuted}" FontSize="10"
                               Margin="0,5,0,0" TextWrapping="Wrap">
                        One subfolder per line, relative to the library root. Families under these
                        folders are skipped by scans and hidden in the browser; their existing data
                        is kept.
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
