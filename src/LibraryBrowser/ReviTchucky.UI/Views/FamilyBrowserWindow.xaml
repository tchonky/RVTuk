<Window x:Class="ReviTchucky.UI.Views.FamilyBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReviTchucky.UI.ViewModels"
        xmlns:ctrl="clr-namespace:ReviTchucky.UI.Controls"
        Title="ReviTchucky — Family Browser"
        Width="900" Height="620" MinWidth="660" MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ReviTchucky.UI;component/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Background><StaticResource ResourceKey="Brush.Bg"/></Window.Background>
    <Window.Foreground><StaticResource ResourceKey="Brush.Text"/></Window.Foreground>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL ─────────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="{StaticResource Brush.Panel}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search + Category + Sync + Settings row -->
            <Grid Grid.Row="0" Margin="6,6,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box with overlay hint text (VisualBrush avoided — render-thread-unsafe in WPF 4.x) -->
                <Grid Grid.Column="0" Margin="0,0,4,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="&#x1F50D; Search..." IsHitTestVisible="False"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Margin="7,0,0,0" VerticalAlignment="Center" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <ComboBox Grid.Column="1" Width="95" Margin="0,0,4,0"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding}"/>
                                        <Style.Triggers>
                                            <!-- "" sentinel = "All categories"; avoids null items in WPF 4.x CollectionView -->
                                            <DataTrigger Binding="{Binding}" Value="">
                                                <Setter Property="Text" Value="All"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Sync icon button (circular arrow path) -->
                <Button Grid.Column="2" Width="28" Margin="0,0,4,0"
                        ToolTip="Sync: scan for file changes and check project family versions"
                        Command="{Binding SyncCommand}">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{StaticResource Brush.Text}"
                                  Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- Settings toggle (gear icon path) -->
                <Button Grid.Column="3" Width="28"
                        ToolTip="Library settings &amp; deep scan"
                        Command="{Binding ToggleSettingsCommand}">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{StaticResource Brush.Text}"
                                  Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.57 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <!-- Update All bar (visible only when outdated families exist) -->
            <Button Grid.Row="1" Margin="6,0,6,4"
                    Command="{Binding UpdateAllCommand}"
                    Visibility="{Binding ShowUpdateAll, Converter={StaticResource BoolVis}}"
                    Content="{Binding OutdatedCount, StringFormat='&#x2191; Update All ({0})'}"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource Brush.AccentDark}"/>

            <!-- Family list -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedItem="{Binding SelectedItem}"
                     BorderThickness="0,1,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FamilyBrowserItemViewModel}">
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Thumbnail}" Width="32" Height="24" Stretch="Uniform"/>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Category}"
                                           Foreground="{StaticResource Brush.TextMuted}" FontSize="10"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#x2713;" Foreground="{StaticResource Brush.Success}"
                                       VerticalAlignment="Center" Margin="4,0,2,0"
                                       Visibility="{Binding ShowUpToDate, Converter={StaticResource BoolVis}}"/>
                            <Border Grid.Column="2" Background="{StaticResource Brush.Accent}" CornerRadius="3"
                                    Padding="4,1" Margin="4,0,2,0"
                                    Visibility="{Binding ShowUpdateAvailable, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="&#x2191; Update" Foreground="White" FontSize="10"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- ── RIGHT PANEL: FAMILY DETAIL ─────────────────────────────── -->
        <Grid Grid.Column="2"
              Visibility="{Binding ShowFamilyDetail, Converter={StaticResource BoolVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,10,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource Brush.Control}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                    <Image Source="{Binding SelectedItem.Thumbnail}" Width="118" Height="80" Stretch="Uniform"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding SelectedItem.DisplayName}" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedItem.Category}"
                               Foreground="{StaticResource Brush.TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    <Border Background="#332200" BorderBrush="{StaticResource Brush.Accent}" BorderThickness="1"
                            Margin="0,6,0,4" Padding="6,3" CornerRadius="3"
                            Visibility="{Binding ShowUpdateInProject, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#x2191; Newer version available in library"
                                   Foreground="{StaticResource Brush.Accent}" FontSize="10"/>
                    </Border>
                    <WrapPanel Margin="0,4,0,0">
                        <Button Content="Load into Project" Command="{Binding LoadFamilyCommand}" Margin="0,0,6,0"/>
                        <Button Content="&#x2191; Update in Project" Command="{Binding UpdateInProjectCommand}"
                                Margin="0,0,6,0"
                                Visibility="{Binding ShowUpdateInProject, Converter={StaticResource BoolVis}}"/>
                        <Button Content="Edit Info" Command="{Binding EditInfoCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" Margin="12,0,12,10">
                <TabItem Header="Instructions">
                    <RichTextBox IsReadOnly="True"
                                 ctrl:RichTextBoxHelper.DocumentXaml="{Binding InstructionsXaml}"/>
                </TabItem>
                <TabItem Header="{Binding Parameters.Count, StringFormat='Parameters ({0})'}">
                    <DataGrid ItemsSource="{Binding Parameters}" AutoGenerateColumns="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"     Binding="{Binding ParameterName}" Width="*"/>
                            <DataGridTextColumn Header="Type"     Binding="{Binding DataType}"      Width="110"/>
                            <DataGridCheckBoxColumn Header="Instance" Binding="{Binding IsInstance}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ── RIGHT PANEL: SETTINGS ──────────────────────────────────── -->
        <ScrollViewer Grid.Column="2"
                      Visibility="{Binding IsShowingSettings, Converter={StaticResource BoolVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,22,28,22" MaxWidth="480">

                <TextBlock Text="Library Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,22"/>

                <TextBlock Text="LIBRARY ROOT FOLDER"
                           Foreground="{StaticResource Brush.TextMuted}" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" IsReadOnly="True" Margin="0,0,6,0"
                             Text="{Binding LibraryFolderPath}"
                             Foreground="{StaticResource Brush.TextMuted}"/>
                    <Button Grid.Column="1" Content="Browse…" Width="72"
                            Click="BrowseLibraryFolder_Click"/>
                </Grid>
                <TextBlock Foreground="{StaticResource Brush.TextMuted}" FontSize="10"
                           Margin="0,5,0,0" TextWrapping="Wrap">
                    The .Setup folder with the database will be created here automatically.
                </TextBlock>

                <Separator Margin="0,26,0,22"/>

                <TextBlock Text="DEEP SCAN" Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"
                           Foreground="{StaticResource Brush.Text}">
                    Deep scan extracts full metadata — category, parameters, and thumbnail — from every
                    family file using the Revit engine. Slower than Sync but captures information that
                    requires an active Revit context. Run after adding many new families or when
                    parameters are missing from the browser.
                </TextBlock>
                <Button Command="{Binding DeepScanCommand}" HorizontalAlignment="Left"
                        Padding="14,7" Background="{StaticResource Brush.AccentDark}"
                        BorderBrush="{StaticResource Brush.Accent}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{StaticResource Brush.Text}"
                                      Data="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Start Deep Scan" FontSize="12"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
